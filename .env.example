# Root-level convenience copy — see server/.env.example and client/.env.example
# for the full, authoritative list of variables each app reads.

# Backend
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net
JWT_SECRET_KEY=change-this-secret-in-production
GEMINI_API_KEY=
GOOGLE_MAPS_API_KEY=
OPENWEATHER_API_KEY=

# Frontend
VITE_API_BASE_URL=http://localhost:8000/api
VITE_GOOGLE_MAPS_API_KEY=
